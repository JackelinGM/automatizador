{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/mimo-v2-free",
  "instructions": ["AGENTS.md"],
  "permission": {
    "edit": "ask",
    "bash": "ask"
  },
  "agent": {
    "python-dev": {
      "description": "Agente especializado en desarrollo Python y Tkinter",
      "mode": "primary",
      "model": "opencode/mimo-v2-free",
      "temperature": 0.3,
      "prompt": "{file:.opencode/agents/python-dev.md}",
      "permission": {
        "edit": "allow",
        "bash": "ask",
        "read": "allow"
      }
    }
  }
}
